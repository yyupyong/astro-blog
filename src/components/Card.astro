---
/** types */
/** utils */
import { formatDate } from "../utils/formatDate";

export interface cardProps {
  title: string;
  href: string;
  url?: string;
  createdAt: string;
  tags?: string[];
}

const { href, title, createdAt, tags = [] } = Astro.props;
---

<article class="group rounded-xl border border-gray-800 bg-gray-900/70 transition hover:-translate-y-1 hover:border-blue-500/70 hover:shadow-lg hover:shadow-blue-500/10">
  <a class="block h-full p-5 md:p-6" href={href}>
    <div class="mb-4 flex flex-wrap gap-2">
      {
        tags.length > 0 ? (
          tags.slice(0, 3).map((tag: string) => (
            <span class="rounded-full border border-blue-500/40 bg-blue-500/10 px-2.5 py-1 text-xs text-blue-300">
              #{tag}
            </span>
          ))
        ) : (
          <span class="rounded-full border border-gray-700 px-2.5 py-1 text-xs text-gray-400">#untagged</span>
        )
      }
    </div>

    <h2 class="min-h-[3.5rem] text-lg md:text-xl font-semibold leading-snug text-white transition group-hover:text-blue-300">
      {title}
    </h2>

    <div class="mt-6 pt-4 border-t border-gray-800 text-sm text-gray-400">
      {new formatDate(createdAt).toJpDateWithWeek()}
    </div>
  </a>
</article>
